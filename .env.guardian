# ─────────────────────────────────────────────────────────────────────────────
# Frontend Guardian – environment configuration
# Copy this file to .env, then fill in your values.
#
# Generate a secure API key:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Security — SDK must send this key in the X-Guardian-Key header
# Leave empty to run without auth (not recommended for production)
GUARDIAN_API_KEY=your-secret-api-key-here

# Server settings
PORT=4000
MAX_EVENTS=10000
MAX_ANALYSES=5000
RULE_WINDOW=300000

# AI analysis (optional — set AI_ENABLED=true to activate)
AI_ENABLED=false
AI_PROVIDER=none         # openai | claude | gemini | ollama | none
AI_API_KEY=
AI_MODEL=
AI_MAX_TOKENS=2048
AI_TIMEOUT_MS=30000

# Required only when AI_PROVIDER=ollama
AI_OLLAMA_BASE_URL=http://localhost:11434

# ── Alerting (optional) ───────────────────────────────────────────────────────
# Slack: paste your Incoming Webhook URL from api.slack.com/apps
ALERT_SLACK_WEBHOOK=

# Generic webhook: receives a JSON POST on every alert
ALERT_WEBHOOK_URL=

# Minimum severity to trigger an alert: info | warning | error | critical
ALERT_MIN_SEVERITY=error

# Cooldown between repeated alerts for the same rule (milliseconds, default 5 min)
ALERT_COOLDOWN_MS=300000

# Public dashboard URL included in Slack alert links
DASHBOARD_URL=http://localhost:3000
