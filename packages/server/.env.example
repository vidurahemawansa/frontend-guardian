# ── Frontend Guardian — Analysis Server ──────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# Every variable has a safe default so the server starts without any changes.
# The only thing you MUST set in production is GUARDIAN_API_KEY.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# Secret shared between the server and the SDK.
# The SDK sends it as the "x-guardian-key" HTTP header on every request.
# The server compares the incoming header against this value.
#
# DEV:  Leave empty — the server skips the check automatically.
# PROD: Set to any strong random string, e.g.:
#         node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#       Then pass the same value to initFrontendGuardian({ apiKey: "..." }) in your app.
GUARDIAN_API_KEY=

# ── In-memory limits ─────────────────────────────────────────────────────────
# Max events kept in RAM before oldest are evicted.
MAX_EVENTS=10000
# Max analysis records kept in RAM.
MAX_ANALYSES=5000
# How many recent events are passed to each rule as context.
RULE_WINDOW=200

# ── AI Analysis (all optional — server works without AI) ─────────────────────
# Set AI_ENABLED=true only when you have a provider configured.
AI_ENABLED=false

# Which provider to use: openai | claude | gemini | ollama | none
#
#  openai  → fastest, cheapest at scale.  Key: https://platform.openai.com/api-keys
#  claude  → best reasoning.              Key: https://console.anthropic.com/settings/keys
#  gemini  → generous free tier.          Key: https://aistudio.google.com/app/apikey
#  ollama  → 100% local, no API key.      Install: https://ollama.com  then: ollama pull qwen2.5-coder:7b
AI_PROVIDER=none

# API key for openai / claude / gemini. Leave empty when using ollama.
AI_API_KEY=

# Model override. Leave empty to use each provider's recommended default:
#   openai  → gpt-4o-mini
#   claude  → claude-3-5-haiku-20241022
#   gemini  → gemini-1.5-flash
#   ollama  → qwen2.5-coder:7b
AI_MODEL=

# Max output tokens per analysis request.
AI_MAX_TOKENS=1024

# Request timeout in ms (increase for ollama — local inference is slower).
AI_TIMEOUT_MS=30000

# Ollama base URL — only used when AI_PROVIDER=ollama.
AI_OLLAMA_BASE_URL=http://localhost:11434
