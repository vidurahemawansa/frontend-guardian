{
  "name": "frontend-guardian",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend Guardian – AI-powered frontend error monitoring monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "tsup": "^8.5.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
